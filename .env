# Razorpay live/test keys for local development
# Replace these values with your real keys from Razorpay Dashboard
RAZORPAY_KEY_ID=rzp_test_duplicate_demo_key
RAZORPAY_KEY_SECRET=rzp_test_duplicate_demo_key

# SSL certificate chain settings for Razorpay cURL
# Recommended secure fix: set path to trusted CA bundle file
# RAZORPAY_CA_BUNDLE=C:/path/to/cacert.pem
# (Alternative fallback variable)
# CURL_CA_BUNDLE=C:/path/to/cacert.pem

# Local development only (NOT for production): disable SSL verification
RAZORPAY_SSL_NO_VERIFY=1

# Local testing only: bypass Razorpay API and simulate successful payment flow
RAZORPAY_MOCK_MODE=1
